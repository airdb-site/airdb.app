---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Starfield from '../components/Starfield.astro';
import AppCard from '../components/AppCard.astro';

const apps = (await getCollection('apps')).sort((a, b) => a.data.order - b.data.order);
const featured = apps.filter((a) => a.data.featured);
const platformCount = new Set(apps.flatMap((a) => a.data.platforms)).size;
const onlineCount = apps.filter((a) => a.data.status === 'online').length;
---

<Base title="airdb 应用中心 · 我们的应用星图">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <Starfield />
    <div class="relative mx-auto max-w-6xl px-5 pb-24 pt-24 sm:pt-32">
      <p
        class="rise font-(family-name:--font-mono) text-xs tracking-[0.35em] text-(--color-aurora)"
        style="--rise-delay:0.05s"
      >
        APP CONSTELLATION
      </p>
      <h1
        class="rise mt-5 max-w-3xl font-(family-name:--font-display) text-4xl font-extrabold leading-[1.15] tracking-tight sm:text-6xl"
        style="--rise-delay:0.15s"
      >
        我们打造的应用,<br />
        都在这片<span class="text-(--color-aurora)">星图</span>上。
      </h1>
      <p class="rise mt-6 max-w-xl text-lg leading-relaxed text-(--color-fog)" style="--rise-delay:0.3s">
        airdb 应用中心汇集我们出品的小程序、iOS、Android 与 Web 应用 ——
        未来,也包括为 AI 智能体而设计的应用。
      </p>
      <div class="rise mt-9 flex flex-wrap gap-3" style="--rise-delay:0.45s">
        <a href="/apps/" class="link-btn primary">浏览全部应用</a>
        <a href="#agents" class="link-btn">为 Agent 而建 →</a>
      </div>

      <dl
        class="rise mt-16 flex flex-wrap gap-x-12 gap-y-5 font-(family-name:--font-mono)"
        style="--rise-delay:0.6s"
      >
        {
          [
            [String(apps.length).padStart(2, '0'), '款应用'],
            [String(onlineCount).padStart(2, '0'), '已上线'],
            [String(platformCount).padStart(2, '0'), '个平台'],
          ].map(([num, label]) => (
            <div>
              <dt class="text-3xl font-bold text-(--color-snow)">{num}</dt>
              <dd class="mt-1 text-xs tracking-[0.2em] text-(--color-fog)">{label}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- 精选应用 -->
  <section class="mx-auto max-w-6xl px-5">
    <div class="reveal mb-8 flex items-end justify-between">
      <div>
        <p class="font-(family-name:--font-mono) text-xs tracking-[0.35em] text-(--color-aurora)">FEATURED</p>
        <h2 class="mt-2 font-(family-name:--font-display) text-2xl font-bold sm:text-3xl">精选应用</h2>
      </div>
      <a
        href="/apps/"
        class="font-(family-name:--font-mono) text-sm text-(--color-fog) transition-colors hover:text-(--color-aurora)"
      >
        全部 →
      </a>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((app, i) => <AppCard app={app} delay={i * 0.08} />)}
    </div>
  </section>

  <!-- Agent 愿景 -->
  <section id="agents" class="mx-auto mt-28 max-w-6xl px-5">
    <div
      class="reveal relative overflow-hidden rounded-2xl border border-(--color-line) bg-(--color-ink) px-7 py-12 sm:px-12"
    >
      <div
        class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-(--color-plat-agent)/10 blur-3xl"
      >
      </div>
      <p class="font-(family-name:--font-mono) text-xs tracking-[0.35em] text-(--color-plat-agent)">
        FOR AGENTS
      </p>
      <h2 class="mt-3 max-w-2xl font-(family-name:--font-display) text-2xl font-bold leading-snug sm:text-3xl">
        下一批用户,是智能体。
      </h2>
      <p class="mt-5 max-w-2xl leading-relaxed text-(--color-fog)">
        应用不只为人而生。我们正在为 AI Agent 设计它们自己需要的应用 ——
        记忆、日程、消息、支付…… 通过 MCP 等开放协议接入,让智能体像人一样"下载安装"自己的工具。
      </p>
      <a href="/apps/?platform=agent" class="link-btn mt-8">查看 Agent 应用</a>
    </div>
  </section>
</Base>
