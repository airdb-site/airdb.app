<canvas id="starfield" class="pointer-events-none absolute inset-0 h-full w-full" aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById('starfield') as HTMLCanvasElement | null;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);

    interface Star {
      x: number;
      y: number;
      r: number;
      base: number;
      speed: number;
      phase: number;
    }

    let stars: Star[] = [];
    let w = 0;
    let h = 0;

    function resize() {
      const rect = canvas!.parentElement!.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      const count = Math.min(220, Math.floor((w * h) / 6500));
      stars = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        r: Math.random() * 1.3 + 0.3,
        base: Math.random() * 0.5 + 0.25,
        speed: Math.random() * 1.2 + 0.4,
        phase: Math.random() * Math.PI * 2,
      }));
    }

    function draw(t: number) {
      ctx.clearRect(0, 0, w, h);
      for (const s of stars) {
        const tw = reduced ? 1 : 0.6 + 0.4 * Math.sin(t / 1000 * s.speed + s.phase);
        ctx.globalAlpha = s.base * tw;
        // 少量青色星点,其余偏白
        ctx.fillStyle = s.phase < 0.9 ? '#55e6c4' : '#dce6f5';
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
      if (!reduced) requestAnimationFrame(draw);
    }

    resize();
    window.addEventListener('resize', resize);
    requestAnimationFrame(draw);
  }
</script>
