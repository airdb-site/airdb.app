---
import type { CollectionEntry } from 'astro:content';
import { PLATFORMS, STATUS } from '../lib/platforms';

interface Props {
  app: CollectionEntry<'apps'>;
  delay?: number;
}

const { app, delay = 0 } = Astro.props;
const { name, tagline, platforms, status, category, icon } = app.data;
const isImage = icon.startsWith('/') || icon.startsWith('http');
---

<a
  href={`/apps/${app.id}/`}
  class="app-card reveal"
  style={`--reveal-delay:${delay}s`}
  data-platforms={platforms.join(',')}
>
  <div class="flex items-start justify-between gap-3">
    <div
      class="flex h-13 w-13 flex-none items-center justify-center overflow-hidden rounded-xl border border-(--color-line) bg-(--color-panel) text-2xl"
    >
      {isImage ? <img src={icon} alt="" class="h-full w-full object-cover" loading="lazy" /> : icon}
    </div>
    <span
      class:list={['flex items-center gap-1.5 font-(family-name:--font-mono) text-[0.68rem]', STATUS[status].className]}
    >
      <i class="status-dot"></i>
      {STATUS[status].label}
    </span>
  </div>

  <div>
    <h3 class="text-lg font-bold text-(--color-snow)">{name}</h3>
    <p class="mt-1 line-clamp-2 text-sm leading-relaxed text-(--color-fog)">{tagline}</p>
  </div>

  <div class="mt-auto flex flex-wrap items-center gap-1.5">
    {
      platforms.map((p) => (
        <span class="plat-badge" style={`--plat:${PLATFORMS[p].color}`}>
          {PLATFORMS[p].short}
        </span>
      ))
    }
    <span class="ml-auto font-(family-name:--font-mono) text-[0.68rem] tracking-wider text-(--color-fog)/70">
      {category}
    </span>
  </div>
</a>
